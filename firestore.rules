rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────

    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if user document exists and is approved
    function isApproved() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    // Check if user is admin
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Site Configuration ───────────────────────────────────────
    match /config/{docId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Semesters ────────────────────────────────────────────────
    match /semesters/{semId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Subjects ─────────────────────────────────────────────────
    match /subjects/{subId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Resources (Drive links, PDFs, etc.) ──────────────────────
    match /resources/{resId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Books ────────────────────────────────────────────────────
    match /books/{bookId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Software ─────────────────────────────────────────────────
    match /software/{swId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Tutorials ────────────────────────────────────────────────
    match /tutorials/{tutId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Notices ──────────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read:  if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read/write their own document (for registration)
      allow read:  if isAuth() && (request.auth.uid == uid || isAdmin());
      // Any authenticated user can create their own doc (registration)
      allow create: if isAuth() && request.auth.uid == uid;
      // Only admins can update/delete user docs (approve/ban)
      allow update: if isAdmin() || (isAuth() && request.auth.uid == uid &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin();
    }
  }
}
